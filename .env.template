# LLM Configuration
# Options: ollama, openai, anthropic, groq
LLM_PROVIDER=ollama
LLM_MODEL=codellama:7b

# API Keys (Required if using Cloud LLMs)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk-...

# Vector Database Path (Default: ./migration_db)
CHROMADB_PATH=./migration_db

# Performance
BATCH_SIZE=32
MAX_WORKERS=4

# RAG Settings
TOP_K=5
SIMILARITY_THRESHOLD=0.7
LOG_LEVEL=INFO
